# ── App ───────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://esimde:password@localhost:5432/esimde_db

# ── OTP / Auth ────────────────────────────────────────
# true = OTP-код отображается прямо в ответе API (только для разработки!)
DEV_AUTH_VISIBLE=true
OTP_EXPIRE_MINUTES=5

# ── SMS — Mobizon ─────────────────────────────────────
MOBIZON_API_KEY=
MOBIZON_SENDER=

# ── WhatsApp — KazInfoteh ─────────────────────────────
KAZINFOTEH_API_KEY=
KAZINFOTEH_BASE_URL=https://api.kazinfoteh.org
KAZINFOTEH_TEMPLATE_ID=

# ── Email SMTP ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@esimde.kz

# ── OpenAI (Voice Assistant) ──────────────────────────
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Files ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── CORS — через запятую ──────────────────────────────
# CORS_ORIGINS=["http://localhost:5173","https://esimde.kz"]

# ── Slots ─────────────────────────────────────────────
SLOT_GENERATE_WEEKS=4
